{
  "name": "sharket-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve seller",
    "serve:seller": "ng serve seller --port=4200",
    "serve:buyer": "ng serve buyer --port=4201",
    "serve:checkout": "ng serve checkout --port=4202",
    "serve:admin": "ng serve admin --port=4203",
    "build": "ng build seller",
    "build:seller": "ng build seller --configuration production",
    "build:buyer": "ng build buyer --configuration production",
    "build:checkout": "ng build checkout --configuration production",
    "build:admin": "ng build admin --configuration production",
    "build:all": "ng build seller --configuration production && ng build buyer --configuration production && ng build checkout --configuration production && ng build admin --configuration production",
    "test": "ng test seller",
    "test:seller": "ng test seller --watch=false",
    "test:buyer": "ng test buyer --watch=false",
    "test:checkout": "ng test checkout --watch=false",
    "test:admin": "ng test admin --watch=false",
    "test:all": "ng test seller --watch=false && ng test buyer --watch=false && ng test checkout --watch=false && ng test admin --watch=false",
    "lint": "ng lint",
    "watch": "ng build seller --watch --configuration development"
  },
  "private": true,
  "engines": {
    "node": ">=22.17.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@angular/animations": "^20.3.24",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.24",
    "@angular/compiler": "^20.3.24",
    "@angular/core": "^20.3.24",
    "@angular/forms": "^20.3.24",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.24",
    "@angular/platform-browser-dynamic": "^20.3.24",
    "@angular/router": "^20.3.24",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.27",
    "@angular/cli": "^20.3.27",
    "@angular/compiler-cli": "^20.3.24",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.2",
    "typescript": "~5.9.3"
  }
}
